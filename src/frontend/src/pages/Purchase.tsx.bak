import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { useAuth } from "@/hooks/use-auth";
import {
  useCompleteOrder,
  useCreateOrder,
  usePurchaseToken,
  useValidateMeter,
} from "@/hooks/use-backend";
import {
  DISCO_OPTIONS,
  type TokenResult,
  type Transaction,
  type ValidatedMeter,
  formatCredit,
} from "@/types";
import { Link } from "@tanstack/react-router";
import {
  AlertCircle,
  ArrowLeft,
  Check,
  CheckCircle2,
  ClipboardCopy,
  Loader2,
  MessageCircle,
  Zap,
} from "lucide-react";
import { useState } from "react";
import { toast } from "sonner";

// ─── Step indicator ───────────────────────────────────────────────────────────
type Step = 1 | 2 | 3 | 4;

const STEPS = [
  { n: 1, label: "Meter" },
  { n: 2, label: "Validate" },
  { n: 3, label: "Pay" },
  { n: 4, label: "Token" },
] as const;

function StepBar({ current }: { current: Step }) {
  return (
    <div className="flex items-center gap-1 mb-6" aria-label="Purchase steps">
      {STEPS.map(({ n, label }, idx) => (
        <div key={n} className="flex items-center flex-1">
          <div className="flex flex-col items-center gap-1 flex-1">
            <div
              className={[
                "w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold transition-smooth",
                current > n
                  ? "step-complete"
                  : current === n
                    ? "step-active"
                    : "step-inactive",
              ].join(" ")}
            >
              {current > n ? <Check className="w-3.5 h-3.5" /> : n}
            </div>
            <span
              className={[
                "text-[10px] font-medium",
                current === n ? "text-primary" : "text-muted-foreground",
              ].join(" ")}
            >
              {label}
            </span>
          </div>
          {idx < STEPS.length - 1 && (
            <div
              className={[
                "h-px flex-1 mb-4 transition-smooth",
                current > n ? "bg-primary/40" : "bg-border",
              ].join(" ")}
            />
          )}
        </div>
      ))}
    </div>
  );
}

// ─── Amount presets ───────────────────────────────────────────────────────────
const AMOUNT_PRESETS = [500, 1000, 2000, 5000] as const;

// ─── Token screen ─────────────────────────────────────────────────────────────
function TokenScreen({
  tokenResult,
  tx,
  onReset,
}: {
  tokenResult: TokenResult;
  tx: Transaction;
  onReset: () => void;
}) {
  function copyToken() {
    navigator.clipboard.writeText(tokenResult.token).then(() => {
      toast.success("Token copied!");
    });
  }

  function shareWhatsApp() {
    const msg = `⚡ Electricity Token from Yusuf Power\n\nToken: ${tokenResult.token}\nUnits: ${tokenResult.units.toFixed(2)} kWh\nMeter: ${tx.meterNumber}\nDiSCo: ${tx.disco}\nAmount: ${formatCredit(tx.creditAmount)}\n\nPowered by Yusuf Power`;
    const url = `https://wa.me/?text=${encodeURIComponent(msg)}`;
    window.open(url, "_blank", "noopener,noreferrer");
  }

  return (
    <div className="space-y-4 fade-up success-pulse" data-ocid="token-result">
      {/* Success header */}
      <div className="flex flex-col items-center gap-3 py-4 text-center">
        <div className="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
          <CheckCircle2 className="w-8 h-8 text-primary" />
        </div>
        <div>
          <h2 className="text-xl font-display font-bold text-foreground">
            Token Generated!
          </h2>
          <p className="text-sm text-muted-foreground mt-1">
            Enter this token on your meter to activate electricity
          </p>
        </div>
      </div>

      {/* Token display */}
      <div className="token-display" data-ocid="token-code">
        {tokenResult.token.match(/.{1,4}/g)?.join(" ") ?? tokenResult.token}
      </div>

      {/* Details */}
      <Card className="bg-card">
        <CardContent className="p-4 space-y-2">
          {[
            { label: "Units", value: `${tokenResult.units.toFixed(2)} kWh` },
            { label: "Meter", value: tx.meterNumber },
            { label: "DiSCo", value: tx.disco },
            { label: "Customer", value: tx.customerName },
            { label: "Amount", value: formatCredit(tx.creditAmount) },
            {
              label: "Status",
              value: "SUCCESS",
              className: "text-primary font-bold",
            },
          ].map(({ label, value, className }) => (
            <div key={label} className="flex justify-between items-center text-sm">
              <span className="text-muted-foreground">{label}</span>
              <span className={`font-medium text-foreground ${className ?? ""}`}>
                {value}
              </span>
            </div>
          ))}
        </CardContent>
      </Card>

      {/* Actions */}
      <Button
        className="w-full gap-2 font-semibold transition-smooth"
        onClick={copyToken}
        data-ocid="copy-token-btn"
      >
        <ClipboardCopy className="w-4 h-4" />
        Copy Token
      </Button>
      <Button
        variant="outline"
        className="w-full gap-2 font-semibold border-[#25D366] text-[#25D366] hover:bg-[#25D366]/10 transition-smooth"
        onClick={shareWhatsApp}
        data-ocid="share-whatsapp-btn"
      >
        <MessageCircle className="w-4 h-4" />
        Share via WhatsApp
      </Button>
      <Button
        variant="ghost"
        size="sm"
        className="w-full text-muted-foreground transition-smooth"
        onClick={onReset}
        data-ocid="new-purchase-btn"
      >
        Buy Another Token
      </Button>
    </div>
  );
}

// ─── Main page ────────────────────────────────────────────────────────────────
export function Purchase() {
  const { isAuthenticated, login } = useAuth();
  const validateMeter = useValidateMeter();
  const purchaseToken = usePurchaseToken();
  const createOrder = useCreateOrder();
  const completeOrder = useCompleteOrder();

  const [step, setStep] = useState<Step>(1);
  const [meterNumber, setMeterNumber] = useState("");
  const [disco, setDisco] = useState("");
  const [amount, setAmount] = useState<number>(1000);
  const [customAmount, setCustomAmount] = useState("");
  const [isCustom, setIsCustom] = useState(false);
  const [validated, setValidated] = useState<ValidatedMeter | null>(null);
  const [tokenResult, setTokenResult] = useState<TokenResult | null>(null);
  const [activeTx, setActiveTx] = useState<Transaction | null>(null);
  const [error, setError] = useState<string | null>(null);

  const effectiveAmount = isCustom ? Number.parseFloat(customAmount) || 0 : amount;

  function reset() {
    setStep(1);
    setMeterNumber("");
    setDisco("");
    setAmount(1000);
    setCustomAmount("");
    setIsCustom(false);
    setValidated(null);
    setTokenResult(null);
    setActiveTx(null);
    setError(null);
    validateMeter.reset();
    purchaseToken.reset();
  }

  async function handleValidate() {
    setError(null);
    if (!meterNumber.trim() || !disco) {
      setError("Please enter a meter number and select your DiSCo.");
      return;
    }
    try {
      const result = await validateMeter.mutateAsync({
        meterNumber: meterNumber.trim(),
        disco,
      });
      setValidated(result);
      setStep(2);
    } catch (err) {
      const msg = err instanceof Error ? err.message : "Validation failed.";
      setError(msg);
    }
  }

  function handleConfirm() {
    if (effectiveAmount < 100) {
      setError("Minimum purchase amount is ₦100.");
      return;
    }
    setError(null);
    setStep(3);
  }

  async function handlePayment() {
    if (!validated) return;
    setError(null);

    const creditKobo = BigInt(Math.round(effectiveAmount * 100));
    try {
      // Create order
      const tx = await createOrder.mutateAsync({
        meterNumber: validated.meterNumber,
        disco: validated.disco,
        customerName: validated.customerName,
        creditAmount: creditKobo,
        paymentMethod: "paystack",
      });

      // Simulate Paystack payment — placeholder
      await new Promise<void>((resolve) => setTimeout(resolve, 1500));

      // Purchase token (complete order)
      const result = await purchaseToken.mutateAsync({
        meterNumber: validated.meterNumber,
        disco: validated.disco,
        amount: creditKobo,
        customerName: validated.customerName,
        paymentMethod: "paystack",
      });

      await completeOrder.mutateAsync({ txId: tx.id, token: result.token, units: result.units });
      setActiveTx({ ...tx, token: result.token, status: "completed" });
      setTokenResult(result);
      setStep(4);
      toast.success("Token generated successfully!");
    } catch (err) {
      const msg = err instanceof Error ? err.message : "Payment failed.";
      setError(msg);
      toast.error(msg);
    }
  }

  if (!isAuthenticated) {
    return (
      <div
        className="flex flex-col items-center gap-5 py-10 text-center fade-up"
        data-ocid="login-gate"
      >
        <div className="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
          <Zap className="w-7 h-7 text-primary" />
        </div>
        <div>
          <h2 className="text-lg font-display font-bold text-foreground">
            Sign in to buy electricity
          </h2>
          <p className="text-sm text-muted-foreground mt-1">
            Secure login required to process payments.
          </p>
        </div>
        <Button
          className="gap-2 px-8 font-semibold transition-smooth"
          onClick={login}
          data-ocid="login-btn"
        >
          Sign in with Internet Identity
        </Button>
        <Button variant="ghost" size="sm" asChild>
          <Link to="/">
            <ArrowLeft className="w-4 h-4 mr-1" />
            Back to Home
          </Link>
        </Button>
      </div>
    );
  }

  const isProcessing =
    validateMeter.isPending ||
    purchaseToken.isPending ||
    createOrder.isPending ||
    completeOrder.isPending;

  return (
    <div className="space-y-2 fade-up" data-ocid="page-purchase">
      {/* Back */}
      {step < 4 && (
        <Button
          variant="ghost"
          size="sm"
          asChild
          className="text-muted-foreground -ml-2 mb-1"
        >
          <Link to="/">
            <ArrowLeft className="w-4 h-4 mr-1" />
            Home
          </Link>
        </Button>
      )}

      <h1 className="text-xl font-display font-bold text-foreground">
        Buy Electricity
      </h1>

      <StepBar current={step} />

      {/* ── Step 1: Meter details ── */}
      {step === 1 && (
        <Card className="bg-card" data-ocid="step-meter">
          <CardHeader className="pb-3">
            <CardTitle className="text-base font-display font-semibold">
              Enter Meter Details
            </CardTitle>
          </CardHeader>
          <CardContent className="space-y-4">
            <div className="space-y-1.5">
              <Label htmlFor="meter-number" className="text-sm font-medium">
                Meter Number
              </Label>
              <Input
                id="meter-number"
                placeholder="e.g. 0422789012345"
                value={meterNumber}
                onChange={(e) => setMeterNumber(e.target.value)}
                className="font-mono text-base"
                data-ocid="meter-input"
              />
            </div>

            <div className="space-y-1.5">
              <Label htmlFor="disco-select" className="text-sm font-medium">
                Distribution Company (DiSCo)
              </Label>
              <Select
                value={disco}
                onValueChange={setDisco}
                data-ocid="disco-select"
              >
                <SelectTrigger
                  id="disco-select"
                  className="w-full"
                  data-ocid="disco-trigger"
                >
                  <SelectValue placeholder="Select your DiSCo…" />
                </SelectTrigger>
                <SelectContent>
                  {DISCO_OPTIONS.map(({ value, label }) => (
                    <SelectItem key={value} value={value}>
                      {label}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>

            {error && (
              <div
                className="flex items-start gap-2 rounded-lg bg-destructive/10 border border-destructive/20 px-3 py-2.5 text-sm text-destructive fade-up"
                data-ocid="error-banner"
              >
                <AlertCircle className="w-4 h-4 shrink-0 mt-0.5" />
                <span>{error}</span>
              </div>
            )}

            <Button
              className="w-full gap-2 font-semibold transition-smooth mt-2"
              onClick={handleValidate}
              disabled={!meterNumber.trim() || !disco || isProcessing}
              data-ocid="validate-btn"
            >
              {isProcessing ? (
                <>
                  <Loader2 className="w-4 h-4 animate-spin" />
                  Validating…
                </>
              ) : (
                <>
                  <Zap className="w-4 h-4" />
                  Validate Meter
                </>
              )}
            </Button>
          </CardContent>
        </Card>
      )}

      {/* ── Step 2: Validation result + amount ── */}
      {step === 2 && validated && (
        <div className="space-y-4" data-ocid="step-amount">
          {/* Customer info */}
          <Card className="bg-primary/5 border-primary/20">
            <CardContent className="p-4 space-y-2">
              <div className="flex items-center gap-2 mb-3">
                <CheckCircle2 className="w-4 h-4 text-primary" />
                <span className="text-sm font-semibold text-primary">
                  Meter Validated
                </span>
              </div>
              {[
                { label: "Customer Name", value: validated.customerName },
                { label: "Meter Number", value: validated.meterNumber },
                { label: "DiSCo", value: validated.disco },
              ].map(({ label, value }) => (
                <div key={label} className="flex justify-between text-sm">
                  <span className="text-muted-foreground">{label}</span>
                  <span className="font-medium text-foreground truncate max-w-[160px]">
                    {value}
                  </span>
                </div>
              ))}
            </CardContent>
          </Card>

          {/* Amount selection */}
          <Card className="bg-card">
            <CardHeader className="pb-3">
              <CardTitle className="text-base font-display font-semibold">
                Select Amount (₦)
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="grid grid-cols-2 gap-2" data-ocid="amount-presets">
                {AMOUNT_PRESETS.map((preset) => (
                  <button
                    key={preset}
                    type="button"
                    onClick={() => {
                      setAmount(preset);
                      setIsCustom(false);
                      setCustomAmount("");
                    }}
                    className={[
                      "py-3 rounded-lg border text-sm font-bold transition-smooth focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring",
                      !isCustom && amount === preset
                        ? "bg-primary text-primary-foreground border-primary shadow-sm"
                        : "bg-background text-foreground border-border hover:bg-muted/60",
                    ].join(" ")}
                    data-ocid={`preset-${preset}`}
                  >
                    ₦{preset.toLocaleString()}
                  </button>
                ))}
              </div>

              <button
                type="button"
                onClick={() => {
                  setIsCustom(true);
                  setAmount(0);
                }}
                className={[
                  "w-full py-3 rounded-lg border text-sm font-bold transition-smooth focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring",
                  isCustom
                    ? "bg-primary text-primary-foreground border-primary shadow-sm"
                    : "bg-background text-foreground border-border hover:bg-muted/60",
                ].join(" ")}
                data-ocid="preset-custom"
              >
                Custom Amount
              </button>

              {isCustom && (
                <div className="flex items-center gap-2 fade-up">
                  <span className="text-foreground font-bold text-base">₦</span>
                  <Input
                    type="number"
                    min={100}
                    placeholder="Enter amount"
                    value={customAmount}
                    onChange={(e) => setCustomAmount(e.target.value)}
                    className="text-base font-mono"
                    data-ocid="custom-amount-input"
                    autoFocus
                  />
                </div>
              )}

              {error && (
                <div className="flex items-start gap-2 rounded-lg bg-destructive/10 border border-destructive/20 px-3 py-2.5 text-sm text-destructive">
                  <AlertCircle className="w-4 h-4 shrink-0 mt-0.5" />
                  <span>{error}</span>
                </div>
              )}

              <div className="flex items-center justify-between py-3 border-t border-border">
                <span className="text-sm text-muted-foreground">Total</span>
                <span className="text-xl font-display font-bold text-foreground">
                  {effectiveAmount > 0
                    ? `₦${effectiveAmount.toLocaleString()}`
                    : "—"}
                </span>
              </div>

              <Button
                className="w-full gap-2 font-semibold transition-smooth"
                onClick={handleConfirm}
                disabled={effectiveAmount < 100}
                data-ocid="confirm-amount-btn"
              >
                Continue to Payment
              </Button>
            </CardContent>
          </Card>
        </div>
      )}

      {/* ── Step 3: Confirmation + payment ── */}
      {step === 3 && validated && (
        <div className="space-y-4" data-ocid="step-confirm">
          <Card className="bg-card">
            <CardHeader className="pb-3">
              <CardTitle className="text-base font-display font-semibold">
                Confirm Purchase
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-3">
              {[
                { label: "Customer Name", value: validated.customerName },
                { label: "Meter Number", value: validated.meterNumber },
                { label: "DiSCo", value: validated.disco },
                {
                  label: "Amount",
                  value: `₦${effectiveAmount.toLocaleString()}`,
                  bold: true,
                },
              ].map(({ label, value, bold }) => (
                <div
                  key={label}
                  className="flex justify-between items-center text-sm py-1 border-b border-border last:border-0"
                >
                  <span className="text-muted-foreground">{label}</span>
                  <span
                    className={
                      bold
                        ? "font-bold text-foreground text-base"
                        : "font-medium text-foreground"
                    }
                  >
                    {value}
                  </span>
                </div>
              ))}
            </CardContent>
          </Card>

          {/* Paystack placeholder */}
          <Card className="bg-muted/30 border-dashed border-border">
            <CardContent className="p-4 text-center space-y-1">
              <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wider">
                Payment Method
              </p>
              <p className="text-sm font-bold text-foreground">
                Paystack (Simulated)
              </p>
              <p className="text-xs text-muted-foreground">
                Live payment integration — coming soon
              </p>
            </CardContent>
          </Card>

          {error && (
            <div className="flex items-start gap-2 rounded-lg bg-destructive/10 border border-destructive/20 px-3 py-2.5 text-sm text-destructive">
              <AlertCircle className="w-4 h-4 shrink-0 mt-0.5" />
              <span>{error}</span>
            </div>
          )}

          <Button
            className="w-full gap-2 font-semibold text-base py-5 transition-smooth"
            onClick={handlePayment}
            disabled={isProcessing}
            data-ocid="pay-btn"
          >
            {isProcessing ? (
              <>
                <Loader2 className="w-4 h-4 animate-spin" />
                Processing Payment…
              </>
            ) : (
              <>
                <Zap className="w-4 h-4" />
                Proceed to Pay ₦{effectiveAmount.toLocaleString()}
              </>
            )}
          </Button>

          <Button
            variant="ghost"
            size="sm"
            className="w-full text-muted-foreground"
            onClick={() => setStep(2)}
            disabled={isProcessing}
          >
            <ArrowLeft className="w-3.5 h-3.5 mr-1" />
            Change Amount
          </Button>
        </div>
      )}

      {/* ── Step 4: Token result ── */}
      {step === 4 && tokenResult && activeTx && (
        <TokenScreen
          tokenResult={tokenResult}
          tx={activeTx}
          onReset={reset}
        />
      )}
    </div>
  );
}
